# .env.example — copy this to .env and fill in real values
# NEVER commit the real .env file to git

# ── Flask ──────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-string

# ── Database ───────────────────────────────────────────────────────────────
# For docker-compose, this is overridden automatically in docker-compose.yml
DATABASE_URL=postgresql://scholaris:yourpassword@db:5432/scholaris
POSTGRES_PASSWORD=yourpassword

# ── Mail (Gmail App Password) ──────────────────────────────────────────────
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-gmail@gmail.com
MAIL_PASSWORD=xxxx xxxx xxxx xxxx
MAIL_DEFAULT_SENDER=your-gmail@gmail.com

# ── Performance flags ──────────────────────────────────────────────────────
# Set to 1 to skip heavy ML model loading at startup (dev only)
FAST_STARTUP=0
